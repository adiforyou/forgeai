# ======================================
# PR REVIEWER PRO - ENVIRONMENT VARIABLES
# ======================================

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Database Configuration
# For development: postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
# For production: Use connection pooler like PgBouncer
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pr_reviewer?schema=public"

# Redis Configuration
# For development: redis://localhost:6380
# For production: Use managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6380

# ======================================
# SECURITY (REQUIRED - CHANGE IN PRODUCTION)
# ======================================

# JWT Secret - Generate with: openssl rand -base64 64
# MUST be at least 32 characters, 64+ recommended for production
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARACTERS_LONG

# Encryption Key for API Keys - Generate with: openssl rand -hex 32
# MUST be exactly 32 characters (64 hex digits = 256 bits)
ENCRYPTION_KEY=CHANGE_ME_TO_A_32_CHARACTER_HEX_STRING_EXACTLY

# ======================================
# EMAIL CONFIGURATION (OPTIONAL)
# ======================================
# Required for email verification and password reset features
# If not configured, emails will be logged to console

# Email sender address
EMAIL_FROM=your-email@example.com

# SMTP Configuration (e.g., Gmail, SendGrid, AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# For Gmail: Create app password at https://myaccount.google.com/apppasswords
# For SendGrid: Use API key as password
# For AWS SES: Configure SMTP credentials

# ======================================
# AI/LLM API KEYS (AT LEAST ONE REQUIRED)
# ======================================
# You need at least ONE of these providers configured
# Users can also add keys via the settings UI

# OpenAI (GPT-4, GPT-3.5)
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
# Get key at: https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=AI...

# ======================================
# GIT PLATFORM TOKENS (OPTIONAL)
# ======================================
# Required if you want to sync repositories automatically
# Users can also add tokens via the settings UI

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:user, read:org
# GITHUB_TOKEN=ghp_...

# GitLab Personal Access Token
# Create at: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_user, read_repository
# GITLAB_TOKEN=glpat-...

# Bitbucket App Password
# Create at: https://bitbucket.org/account/settings/app-passwords/
# Required permissions: Repository Read, Pull Request Read
# BITBUCKET_USERNAME=your-username
# BITBUCKET_APP_PASSWORD=...

# ======================================
# WEBHOOK CONFIGURATION (OPTIONAL)
# ======================================
# Required if you want to receive webhooks from Git platforms
# Generate with: openssl rand -hex 32

# WEBHOOK_SECRET=your-webhook-secret-here

# ======================================
# RATE LIMITING (OPTIONAL)
# ======================================
# Configure rate limits for API endpoints

# Default: 100 requests per 15 minutes
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Auth endpoints: 20 requests per 15 minutes
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=20

# ======================================
# LOGGING (OPTIONAL)
# ======================================

# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ======================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ======================================
# Before deploying to production, ensure:
# [ ] Generate new JWT_SECRET and ENCRYPTION_KEY with strong random values
# [ ] Configure real SMTP credentials for email sending
# [ ] Add at least one AI provider API key
# [ ] Set NODE_ENV=production
# [ ] Use HTTPS/SSL for all connections
# [ ] Configure proper FRONTEND_URL with your domain
# [ ] Set up database backups and monitoring
# [ ] Configure firewall rules for Redis and PostgreSQL
# [ ] Enable audit logging for sensitive operations
# [ ] Set up uptime monitoring and alerting
# [ ] Remove all .env files from git history
# [ ] Use secrets manager (AWS Secrets Manager, etc.) for production secrets
